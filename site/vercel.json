{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.devsoy.online" }],
      "destination": "https://devsoy.online/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
